{
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm run *)",
      "Bash(pnpm test*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm exec prettier *)",
      "Bash(pnpm exec tsc *)",
      "Bash(pnpm exec eslint *)",
      "Bash(npx drizzle-kit *)",
      "Bash(node --version)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git show *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git commit --no-verify*)",
      "Bash(psql * DROP *)",
      "Bash(psql * TRUNCATE *)",
      "Bash(drizzle-kit push*)"
    ]
  },
  "env": {
    "NODE_OPTIONS": "--enable-source-maps"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Bash\"",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous-bash.sh"
          }
        ]
      },
      {
        "matcher": "tool == \"Edit\" || tool == \"Write\"",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-domain-violations.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-forbidden-patterns.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-protected-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tool == \"Edit\" || tool == \"Write\"",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-format.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-typecheck.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/test-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-audit.sh"
          }
        ]
      }
    ]
  }
}
