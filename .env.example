NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgres://postgres:postgres@localhost:5432/tte_ecommerce
DATABASE_POOL_MAX=20

REDIS_URL=redis://localhost:6379

# minimum 32 random bytes — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

EVENT_BUS_DRIVER=outbox
RABBITMQ_URL=amqp://localhost:5672

PAYMENT_PROVIDER=mock

# Email — set EMAIL_PROVIDER=resend and supply RESEND_API_KEY for production
# Use EMAIL_PROVIDER=console (default) in development to print OTPs to stdout
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@yourdomain.com
RESEND_API_KEY=
